<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HigherOrLower.ViewModels"
             x:Class="HigherOrLower.Views.GameOverPage"
             x:DataType="vm:GameOverPageViewModel"
             Title="Higher or Lower | Game Over">

    <ContentPage.Content>

        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="Game Over!"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="{Binding PlayerName, StringFormat='Player: {0}'}"
                   FontSize="20"
                   HorizontalOptions="Center" />

            <Label Text="{Binding Score, StringFormat='Final Score: {0}'}"
                   FontSize="24"
                   HorizontalOptions="Center" />

            <Button Text="Play Again"
                    Command="{Binding PlayAgainCommand}"
                    HorizontalOptions="Center" />

        </VerticalStackLayout>

    </ContentPage.Content>
</ContentPage>